<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetSicilyLines.Coordonnees"
             Title="Mes coordonnées"
             Background="White"
             >

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <Image Source="gospel1.png"
                   HeightRequest="80"
                   HorizontalOptions="Center" />


            <Label Text="Nom" TextColor="Black" FontAttributes="Bold"/>
            <Entry x:Name="EntryNom" BackgroundColor="Black"/>

            <Label Text="Prénom" TextColor="Black" FontAttributes="Bold"/>
            <Entry x:Name="EntryPrenom" BackgroundColor="Black"/>


            <Label Text="Email" TextColor="Black" FontAttributes="Bold"/>
            <Entry x:Name="EntryEmail" BackgroundColor="Black"/>

            <Label Text="Téléphone" TextColor="Black" FontAttributes="Bold"/>
            <Entry x:Name="EntryTelephone" Keyboard="Telephone" BackgroundColor="Black"/>

            <Label Text="Adresse" TextColor="Black" FontAttributes="Bold"/>
            <Entry x:Name="EntryAdresse" BackgroundColor="Black"/>

            <Label Text="Ville" TextColor="Black" FontAttributes="Bold"/>
            <Entry x:Name="EntryVille" BackgroundColor="Black"/>

            <Label Text="Code Postal" TextColor="Black" FontAttributes="Bold"/>
            <Entry x:Name="EntryCodePostal" Keyboard="Numeric" BackgroundColor="Black"/>

            <Button Text="Enregistrer"
                    BackgroundColor="Blue"
                    TextColor="White"
                    Clicked="BtnEnregistrer_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>