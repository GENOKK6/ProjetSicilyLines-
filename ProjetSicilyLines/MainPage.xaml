<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetSicilyLines.MainPage"
             Title="Accueil"
             Background="White">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

        
        <Image Source="gospel1.png"
               HeightRequest="100"
               HorizontalOptions="Center" />

        <Label Text="Sicily Lines"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="Black" />

        <Button Text="Modifier ses coordonnées"
                BackgroundColor="BLUE"
                TextColor="White"
                Clicked="BtnCoordonnees_Clicked" />

        <Button Text="Lister ses réservations"
                BackgroundColor="Blue"
                TextColor="White"
                Clicked="BtnReservations_Clicked" />

        
        <Button Text="Se déconnecter"
                BackgroundColor="Gray"
                TextColor="White"
                Clicked="BtnDeconnexion_Clicked" />

    </VerticalStackLayout>

</ContentPage>