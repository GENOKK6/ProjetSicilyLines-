<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetSicilyLines.Reservations"
             Title="Mes réservations">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Image Source="gospel1.png"
               HeightRequest="80"
               HorizontalOptions="Center" />

        <Label Text="Mes réservations"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalOptions="Center"/>

        <CollectionView x:Name="ListeReservations">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5"
                           Padding="15"
                           BackgroundColor="{Binding Couleur}">
                        <VerticalStackLayout>
                            <Label Text="{Binding NomTraversee}"
                                   FontAttributes="Bold"
                                   FontSize="16"/>
                            <Label Text="{Binding DateDepart, StringFormat='Départ : {0:dd/MM/yyyy}'}"
                                   FontSize="14"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>