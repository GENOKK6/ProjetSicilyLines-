<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetSicilyLines.Reservations"
             Title="Mes réservations"
             Background="White">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Image Source="gospel1.png"
               HeightRequest="80"
               HorizontalOptions="Center" />

        <ListView x:Name="lv"
                  SeparatorColor="White"
                  RowHeight="80"
                  BackgroundColor="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Frame Margin="5" Padding="10"
                               BackgroundColor="{Binding Couleur}">
                            <VerticalStackLayout>
                                <Label Text="{Binding NomTraversee}"
                                       FontAttributes="Bold"
                                       FontSize="16"/>
                                <Label Text="{Binding DateDepart}"
                                       FontSize="14"/>
                            </VerticalStackLayout>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>
</ContentPage>